{
  "name": "Portfolio Rebalancer",
  "image": "oven/bun:1",
  "runArgs": ["--dns", "192.168.1.202"],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    },
    "ghcr.io/meaningful-ooo/devcontainer-features/fish:2.0.0": {}
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/bun/.ssh,type=bind,readonly"
  ],
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.preferences.importModuleSpecifier": "relative"
      }
    }
  },
  "postCreateCommand": "git remote set-url origin ssh://git@forgejo.butorov.cc:222/bap/PortfolioRebalancer.git && bun install && git config --global user.name 'AButorov' && git config --global user.email 'butorov.ap@gmail.com'",
  "remoteUser": "bun"
}
